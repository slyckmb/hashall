[Unit]
Description=Run hashall payload orphan snapshot every 6 hours
Documentation=file:///home/michael/dev/work/hashall/docs/tooling/payload-orphan-audit-automation.md

[Timer]
OnCalendar=*-*-* 00,06,12,18:15:00
Persistent=true
AccuracySec=5m
RandomizedDelaySec=5m
Unit=hashall-payload-orphan-snapshot.service

[Install]
WantedBy=timers.target
